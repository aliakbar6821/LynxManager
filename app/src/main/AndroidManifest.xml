<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:label="@string/app_name"
        android:icon="@drawable/ic_lynx"
        android:theme="@style/Theme.LynxManager">

        <activity
            android:name=".LynxManagerActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter android:priority="1">
                <action android:name="com.android.settings.action.IA_SETTINGS" />
                <category android:name="com.android.settings.category.ia.system" />
            </intent-filter>
            <meta-data
                android:name="com.android.settings.summary"
                android:value="@string/app_summary" />
        </activity>

        <provider
            android:name=".LynxSearchIndexablesProvider"
            android:authorities="com.lynx.manager"
            android:multiprocess="false"
            android:grantUriPermissions="true"
            android:permission="android.permission.READ_SEARCH_INDEXABLES"
            android:exported="true">
            <intent-filter>
                <action android:name="android.content.action.SEARCH_INDEXABLES_PROVIDER" />
            </intent-filter>
        </provider>

    </application>
</manifest>
