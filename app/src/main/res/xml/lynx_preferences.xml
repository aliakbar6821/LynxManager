<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="Integrity Configuration"
        app:allowDividerAbove="true">

        <Preference
            android:key="pref_add_pif"
            android:title="Google PIF (JSON)"
            android:summary="⚠️ No PIF — using hardware fingerprint"
            app:icon="@android:drawable/ic_menu_edit" />

        <Preference
            android:key="pref_add_keybox"
            android:title="Hardware Keybox (XML)"
            android:summary="⚠️ No Keybox — using hardware attestation"
            app:icon="@android:drawable/ic_lock_lock" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Tools &amp; Maintenance"
        app:allowDividerAbove="true">

        <Preference
            android:key="pref_refresh_spoof"
            android:title="Refresh Spoof"
            android:summary="Kill &amp; restart GMS to load new data (no reboot needed)"
            app:icon="@android:drawable/ic_menu_rotate" />

        <Preference
            android:key="pref_reset_spoofing"
            android:title="Reset All Spoofing"
            android:summary="Delete PIF &amp; Keybox — revert to real hardware"
            app:icon="@android:drawable/ic_menu_revert" />

    </PreferenceCategory>

</PreferenceScreen>
